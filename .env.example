# Copy this file to `.env` and adjust values for your machine:
#   cp .env.example .env
#
# Docker Compose automatically reads `.env` from this directory.

# Image/container naming
COMPOSE_PROJECT_NAME=dbat-dev
DBAT_IMAGE_NAME=dbat-dev:ubuntu24.04
DBAT_CONTAINER_NAME=dbat-dev

# Host workspace path mounted into the container.
# Use "." when running compose from the repository root.
DBAT_WORKSPACE=.

# Build/test configuration defaults (consumed by helper scripts)
BUILD_TYPE=Debug
BUILD_DIR=build
INSTALL_DIR=.install

# Parallel jobs for builds (empty = tool default)
JOBS=

# Optional CPM cache directory inside the container
CPM_CACHE_DIR=/workspace/.cache/cpm
