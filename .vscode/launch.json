{
    "version": "0.2.0",
    "configurations": [
        // --- Python mode: server ---
        {
            "name": "DBAT: Server (Python)",
            "type": "debugpy",
            "request": "launch",
            "module": "dbat.game", // python -m dbat.game
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false, // step into libs/Cython if needed
            "subProcess": true, // follow forks/spawns
            "env": {} // add env here if needed
      // Interpreter: uses the one you selected in VS Code (point it to .venv)
        },
        // --- Python mode: portal ---
        {
            "name": "DBAT: Portal (Python)",
            "type": "debugpy",
            "request": "launch",
            "module": "dbat.portal",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "subProcess": true,
            "env": {}
        },
        {
            "name": "DBAT: (GDB) server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "dbat.game"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "DBAT: (GDB) portal",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "dbat.portal"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "DBAT: (GDB) Migrate",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/compiled/dbat_migrate",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LSAN_OPTIONS",
                    "value": "verbosity=1:log_threads=1"
                }
            ],
            // You can also set ASAN_OPTIONS here if needed],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "/usr/bin/gdb",
        },
    ]
}