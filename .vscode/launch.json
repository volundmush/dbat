{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DBAT: (GDB) server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "dbat.game"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "/opt/gcc-15/lib64:${env:LD_LIBRARY_PATH}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                { "text": "python import sys; sys.path.insert(0, '/opt/gcc-15/share/gcc-15.1.0/python')" }, 
                { "text": "python from libstdcxx.v6.printers import register_libstdcxx_printers; register_libstdcxx_printers(None)" }
            ]
        },
        {
            "name": "DBAT: (GDB) portal",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "-m",
                "dbat.portal"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "/opt/gcc-15/lib64:${env:LD_LIBRARY_PATH}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                { "text": "python import sys; sys.path.insert(0, '/opt/gcc-15/share/gcc-15.1.0/python')" }, 
                { "text": "python from libstdcxx.v6.printers import register_libstdcxx_printers; register_libstdcxx_printers(None)" }
            ]
        },
        {
            "name": "DBAT: (GDB) Migrate",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/compiled/dbat_migrate",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LSAN_OPTIONS",
                    "value": "verbosity=1:log_threads=1"
                },
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "/opt/gcc-15/lib64:${env:LD_LIBRARY_PATH}"
                }
            ],
            // You can also set ASAN_OPTIONS here if needed],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                { "text": "python import sys; sys.path.insert(0, '/opt/gcc-15/share/gcc-15.1.0/python')" }, 
                { "text": "python from libstdcxx.v6.printers import register_libstdcxx_printers; register_libstdcxx_printers(None)" }
            ],
            "miDebuggerPath": "/usr/bin/gdb",
        },
        {
            "name": "DBAT: (GDB) New Server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/compiled/dbat_server",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LSAN_OPTIONS",
                    "value": "verbosity=1:log_threads=1"
                },
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "/opt/gcc-15/lib64:${env:LD_LIBRARY_PATH}"
                }
            ],
            // You can also set ASAN_OPTIONS here if needed],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                { "text": "python import sys; sys.path.insert(0, '/opt/gcc-15/share/gcc-15.1.0/python')" }, 
                { "text": "python from libstdcxx.v6.printers import register_libstdcxx_printers; register_libstdcxx_printers(None)" }
            ],
            "miDebuggerPath": "/usr/bin/gdb",
        }
    ]
}