#JWT SECRET: supersecretkeythatshouldbereplaced
JWT_SECRET=supersecretkeythatshouldbereplaced
JWT_EXPIRE_MINUTES=30

# Shared TLS information that'll be used wherever appropriate.
# TLS will only be enabled if both the cert file and key file are present.
TLS_CERT_FILE=localhost.pem
TLS_KEY_FILE=localhost-key.pem

# The networking configuration for the telnet portal.
TELNET_HOST=*
TELNET_PORT=1280

TELNETS_HOST=*
TELNETS_PORT=1281

# The networking configuration for the HTTP(S) server.
# If HTTPS is enabled, HTTP will automatically redirect to HTTPS.

HTTP_HOST=*
HTTP_PORT=8080

HTTPS_HOST=*
HTTPS_PORT=8443
